{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"ignoreDeprecations": "6.0",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"lib": ["ES2022", "DOM"]
	},
	"include": ["src/**/*.ts", "test/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}

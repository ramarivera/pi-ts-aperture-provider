{
  "providerName": "aperture-provider",
  "baseUrl": "https://aperture-ai.xalda-procyon.ts.net/v1",
  "apiKey": "-",
  "modelsPath": "/models",
  "modelsDev": {
    "enabled": true,
    "url": "https://models.dev/api.json",
    "cacheTtlMs": 3600000,
    "providerAliases": {
      "your-aperture-provider-id": [
        "openai",
        "openai-responses"
      ]
    }
  },
  "resolution": {
    "requireModelsDevForCapabilities": true,
    "useKnownModelFallbacks": true,
    "skipModelsMissingCapabilities": true,
    "providerLabelInName": true,
    "apiRules": [
      {
        "match": [
          "/v1/messages"
        ],
        "api": "anthropic-messages"
      },
      {
        "match": [
          "/v1/responses"
        ],
        "api": "openai-responses"
      }
    ]
  },
  "fallbackMetadata": {
    "k2.5": {
      "reasoning": true,
      "input": [
        "text"
      ],
      "contextWindow": 262144,
      "maxTokens": 16384
    }
  },
  "modelOverrides": {
    "openai/gpt-5": {
      "contextWindow": 128000,
      "maxTokens": 32768
    }
  }
}
